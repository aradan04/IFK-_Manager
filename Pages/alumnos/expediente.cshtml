@page
@model ProyectoIFK.Pages.alumnos.expedienteModel

@{
    ViewData["Title"] = "Expediente";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <title>Expediente de Alumnado</title>

    <link rel="stylesheet" href="~/css/ifk.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>

<body>

    <div class="header">

        <div class="header-title">
            IFK MANAGER
        </div>

        <a href="/Index" class="logout">
            <i class="fas fa-sign-out-alt"></i>
            Cerrar sesión
        </a>

    </div>

    <div class="main">

        <div class="sidebar">

            <a href="/Inicio">
                <i class="fas fa-home"></i>
                Inicio
            </a>

            <a href="/alumnos/gestion">
                <i class="fas fa-users"></i>
                Alumnos
            </a>

            <a href="/Finanzas">
                <i class="fas fa-money-bill"></i>
                Finanzas
            </a>

            <a href="/torneos/gestorTorneo">
                <i class="fas fa-trophy"></i>
                Torneos
            </a>

            <a href="/reportes">
                <i class="fas fa-chart-bar"></i>
                Reportes
            </a>

            <a href="/personal/menuPersonal">
                <i class="fas fa-user"></i>
                Personal
            </a>

        </div>

        <div class="content">

            <div class="page-box">

                <h1 class="expediente-title">
                    EXPEDIENTE DE ALUMNADO
                </h1>

                <div class="busqueda-expediente">

                    <label>
                        BUSCAR POR MATRÍCULA O NOMBRE:
                    </label>

                    <input type="text"
                           class="ifk-input">

                </div>

                <!-- PESTAÑAS -->

                <div class="tabs">

                    <button class="tab-btn active"
                            onclick="mostrarTab(event,'datos')">
                        DATOS PERSONALES
                    </button>

                    <button class="tab-btn"
                            onclick="mostrarTab(event,'medicos')">
                        DATOS MÉDICOS
                    </button>

                    <button class="tab-btn"
                            onclick="mostrarTab(event,'historial')">
                        HISTORIAL DE CINTAS
                    </button>

                </div>

                <!-- DATOS PERSONALES -->

                <div id="datos" class="tab-content active-tab">

                    <div class="expediente-box">

                        <div class="avatar-box">

                            <img src="~/imagenes/icons/user-solid.png"
                                 class="expediente-avatar">

                        </div>

                        <div class="expediente-form">

                            <label>ALUMNO:</label>

                            <input type="text"
                                   value="Juan Pérez"
                                   readonly
                                   class="ifk-input">

                            <label>MATRÍCULA:</label>

                            <input type="text"
                                   value="2026-001"
                                   readonly
                                   class="ifk-input">

                            <label>GRADO ACTUAL:</label>

                            <input type="text"
                                   value="Naranja (10mo Kyu)"
                                   readonly
                                   class="ifk-input">

                            <label>FECHA DE INGRESO:</label>

                            <input type="text"
                                   value="15/01/2026"
                                   readonly
                                   class="ifk-input">

                        </div>

                    </div>

                </div>

                <!-- DATOS MEDICOS -->

                <div id="medicos" class="tab-content">

                    <div class="expediente-box">

                        <div class="avatar-box">

                            <img src="~/imagenes/icons/user-solid.png"
                                 class="expediente-avatar">

                        </div>

                        <div class="expediente-form">

                            <label>ALUMNO:</label>

                            <input type="text"
                                   value="Juan Pérez"
                                   readonly
                                   class="ifk-input">

                            <label>ALERGIAS:</label>

                            <input type="text"
                                   value="Ninguna"
                                   readonly
                                   class="ifk-input">

                            <label>PESO:</label>

                            <input type="text"
                                   value="72 Kg"
                                   readonly
                                   class="ifk-input">

                            <label>TIPO DE SANGRE:</label>

                            <input type="text"
                                   value="O+"
                                   readonly
                                   class="ifk-input">

                        </div>

                    </div>

                </div>

                <!-- HISTORIAL -->

                <div id="historial" class="tab-content">

                    <div class="expediente-box">

                        <div class="avatar-box">

                            <img src="~/imagenes/icons/user-solid.png"
                                 class="expediente-avatar">

                        </div>

                        <div class="expediente-form">

                            <label>ALUMNO:</label>

                            <input type="text"
                                   value="Juan Pérez"
                                   readonly
                                   class="ifk-input">

                        </div>

                        <table class="tabla-historial">

                            <thead>

                                <tr>
                                    <th>FECHA</th>
                                    <th>GRADO / CINTA</th>
                                    <th>SENSEI EVALUADOR</th>
                                    <th>ESTATUS</th>
                                </tr>

                            </thead>

                            <tbody>

                                <tr>
                                    <td>15/01/2026</td>
                                    <td>Blanca</td>
                                    <td>J. Roberto Méndez</td>
                                    <td>Aprobado</td>
                                </tr>

                                <tr>
                                    <td>10/03/2026</td>
                                    <td>Amarilla</td>
                                    <td>J. Roberto Méndez</td>
                                    <td>Aprobado</td>
                                </tr>

                                <tr>
                                    <td>05/04/2026</td>
                                    <td>Naranja</td>
                                    <td>J. Roberto Méndez</td>
                                    <td>Pendiente</td>
                                </tr>

                            </tbody>

                        </table>

                        <div class="historial-btn-container">

                            <button class="btn-reporte">

                                REGISTRAR NUEVA
                                PROMOCIÓN

                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        function mostrarTab(event, id) {

            document
                .querySelectorAll(".tab-content")
                .forEach(x => x.classList.remove("active-tab"));

            document
                .querySelectorAll(".tab-btn")
                .forEach(x => x.classList.remove("active"));

            document
                .getElementById(id)
                .classList.add("active-tab");

            event.target.classList.add("active");
        }

    </script>

</body>
</html>