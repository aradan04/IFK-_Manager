@page
@model ProyectoIFK.Pages.alumnos.asistenciaModel
@{
    ViewData["Title"] = "Lista de Asistencia";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Lista de Asistencia</title>
    <link rel="stylesheet" href="~/css/ifk.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>

    <div class="header">
        <div class="header-title">IFK MANAGER</div>
        <a href="/Index" class="logout"><i class="fas fa-sign-out-alt"></i> Cerrar sesión</a>
    </div>

    <div class="main">

        <div class="sidebar">
            <a href="/Inicio"><i class="fas fa-home"></i> Inicio</a>
            <a href="/alumnos/gestion"><i class="fas fa-users"></i> Alumnos</a>
            <a href="/Finanzas"><i class="fas fa-money-bill"></i> Finanzas</a>
            <a href="/torneos/gestorTorneo"><i class="fas fa-trophy"></i> Torneos</a>
            <a href="/reportes"><i class="fas fa-chart-bar"></i> Reportes</a>
            <a href="/personal/menuPersonal"><i class="fas fa-user"></i> Personal</a>
        </div>

        <div class="content">
            <div class="page-box">
                @if (TempData["Mensaje"] != null) { 
                    <div style="text-align:center; padding:15px; background:#d4edda; color:#155724; border-radius:5px; margin-bottom:15px;">
                        @TempData["Mensaje"]
                    </div> 
                }

                <form method="post">
                    <div class="asistencia-header">
                        <h1 class="asistencia-title">LISTA DE ASISTENCIA</h1>
                    </div>

                    <div class="asistencia-clase">
                        <label>CLASE:</label>
                        <select id="filtroClase" onchange="filtrarTabla()" class="ifk-input">
                            <option value="TODOS">TODOS</option>
                            <option value="ADULTOS">ADULTOS</option>
                            <option value="NIÑOS">NIÑOS</option>
                        </select>
                    </div>

                    <table class="tabla-asistencia" id="tablaAsistencia">
                        <thead>
                            <tr>
                                <th>NOMBRE DEL ALUMNO</th>
                                <th>GRADO</th>
                                <th>ESTATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.ListaAlumnosAsistencia.Count; i++)
                            {
                                <input type="hidden" asp-for="ListaAlumnosAsistencia[i].IdAlumno" />
                                <tr class="fila-alumno" data-categoria="ADULTOS">
                                    <td>@Model.ListaAlumnosAsistencia[i].NombreCompleto</td>
                                    <td>@Model.ListaAlumnosAsistencia[i].KyuActual</td>
                                    <td>
                                        <input type="checkbox" asp-for="ListaAlumnosAsistencia[i].Asistio" /> Asistió
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="asistencia-btn-container">
                        <button type="submit" class="btn-asistencia">GUARDAR<br />ASISTENCIA</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function filtrarTabla() {
            var filtro = document.getElementById("filtroClase").value;
            var filas = document.getElementsByClassName("fila-alumno");
            for (var i = 0; i < filas.length; i++) {
                if (filtro === "TODOS" || filas[i].getAttribute("data-categoria") === filtro) {
                    filas[i].style.display = "";
                } else {
                    filas[i].style.display = "none";
                }
            }
        }
    </script>
</body>
</html>