@page

@{
    ViewData["Title"] = "Registro de Pago";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <title>Registro de Pago</title>

    <link rel="stylesheet" href="~/css/ifk.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>

<body>

    <div class="header">

        <div class="header-title">
            IFK MANAGER
        </div>

        <a href="/Index" class="logout">
            <i class="fas fa-sign-out-alt"></i>
            Cerrar sesión
        </a>

    </div>

    <div class="main">

        <div class="sidebar">

            <a href="/Inicio">
                <i class="fas fa-home"></i>
                Inicio
            </a>

            <a href="/alumnos/gestion">
                <i class="fas fa-users"></i>
                Alumnos
            </a>

            <a href="/Finanzas">
                <i class="fas fa-money-bill"></i>
                Finanzas
            </a>

            <a href="#">
                <i class="fas fa-trophy"></i>
                Torneos
            </a>

            <a href="#">
                <i class="fas fa-file"></i>
                Reportes
            </a>

        </div>

        <div class="content">

            <div class="page-box">

                <h1 class="finanzas-title">
                    REGISTRO DE PAGO
                </h1>

                <!-- BUSQUEDA -->

                <div class="buscar-container">

                    <label>
                        Buscar por matrícula o nombre:
                    </label>

                    <input type="text"
                           class="ifk-input">

                </div>

                <!-- FORMULARIO -->

                <div class="pago-box">

                    <div class="alumno-row">

                        <label>ALUMNO:</label>

                        <input type="text"
                               class="ifk-input">

                    </div>

                    <div class="pago-grid">

                        <!-- CONCEPTO -->

                        <div>

                            <label>CONCEPTO:</label>

                            <select class="ifk-input">

                                <option selected disabled>
                                    Seleccione un concepto
                                </option>

                                <option>Mensualidad</option>
                                <option>Examen de grado</option>
                                <option>Inscripción</option>
                                <option>Equipo / Uniforme</option>
                                <option>Torneo</option>
                                <option>Camp</option>
                                <option>Seminario</option>
                                <option>Otro</option>

                            </select>

                        </div>

                        <!-- MONTO -->

                        <div>

                            <label>MONTO:</label>

                            <input type="number"
                                   class="ifk-input"
                                   placeholder="$0.00">

                        </div>

                        <!-- METODO -->

                        <div>

                            <label>MÉTODO DE PAGO:</label>

                            <select class="ifk-input">

                                <option selected disabled>
                                    Seleccione método
                                </option>

                                <option>Efectivo</option>
                                <option>Transferencia</option>
                                <option>Tarjeta</option>

                            </select>

                        </div>

                    </div>

                </div>

                <div class="registro-pago-container">

                    <button class="btn-registrar-pago">
                        REGISTRAR PAGO
                    </button>

                </div>

                <!-- HISTORIAL -->

                <h2 class="historial-title">
                    HISTORIAL DE PAGOS
                </h2>

                <table class="tabla-pagos">

                    <thead>

                        <tr>

                            <th>FECHA</th>
                            <th>MATRÍCULA</th>
                            <th>CONCEPTO</th>
                            <th>MONTO</th>
                            <th>MÉTODO</th>
                            <th>ESTATUS</th>

                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td>05/04/2026</td>
                            <td>2026-001</td>
                            <td>Mensualidad Abril</td>
                            <td>$850.00</td>
                            <td>Efectivo</td>
                            <td>Completado</td>
                        </tr>

                        <tr>
                            <td>05/04/2026</td>
                            <td>2026-002</td>
                            <td>Mensualidad Abril</td>
                            <td>$850.00</td>
                            <td>Transferencia</td>
                            <td>Completado</td>
                        </tr>

                        <tr>
                            <td>04/04/2026</td>
                            <td>2026-004</td>
                            <td>Examen de grado</td>
                            <td>$1200.00</td>
                            <td>Tarjeta</td>
                            <td>Completado</td>
                        </tr>

                        <tr>
                            <td>03/04/2026</td>
                            <td>2026-005</td>
                            <td>Equipo / Uniforme</td>
                            <td>$950.00</td>
                            <td>Efectivo</td>
                            <td>Pendiente</td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>
</html>