@page
@model ProyectoIFK.Pages.FinanzasModel
@{
    ViewData["Title"] = "Registro de Pago";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registro de Pago</title>
    <link rel="stylesheet" href="~/css/ifk.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        @@media print {
            .header, .sidebar, .btn-registrar-pago, .buscar-container { display: none !important; }
            .page-box { border: none !important; box-shadow: none !important; width: 100%; }
            #statusTransferencia { display: block !important; }
        }
        .resultados-busqueda { border: 1px solid #ddd; background: #fff; position: absolute; width: 100%; z-index: 1000; display: none; }
        .item-resultado { padding: 10px; cursor: pointer; color: #333; }
        .item-resultado:hover { background: #f0f0f0; }
        .alert-transferencia { display: none; font-weight: bold; margin-top: 10px; }
    </style>
</head>

<body>
    <div class="header">
        <div class="header-title">IFK MANAGER</div>
        <a href="/Index" class="logout"><i class="fas fa-sign-out-alt"></i> Cerrar sesión</a>
    </div>

    <div class="main">
        <div class="sidebar">
            <a href="/Inicio"><i class="fas fa-home"></i> Inicio</a>
            <a href="/alumnos/gestion"><i class="fas fa-users"></i> Alumnos</a>
            <a href="/Finanzas"><i class="fas fa-money-bill"></i> Finanzas</a>
            <a href="/torneos/gestorTorneo"><i class="fas fa-trophy"></i> Torneos</a>
            <a href="/reportes"><i class="fas fa-chart-bar"></i> Reportes</a>
            <a href="/personal/menuPersonal"><i class="fas fa-user"></i> Personal</a>
        </div>

        <div class="content">
            <div class="page-box">
                <h1 class="finanzas-title">REGISTRO DE PAGO</h1>
                
                <div class="buscar-container" style="position: relative;">
                    <label>Buscar por matrícula o nombre:</label>
                    <input type="text" id="inputBusqueda" class="ifk-input" placeholder="Escribe para buscar..." autocomplete="off">
                    <div id="listaResultados" class="resultados-busqueda"></div>
                </div>

                <div class="pago-box">
                    <div class="alumno-row">
                        <label>ALUMNO:</label>
                        <input type="text" id="nombreAlumnoInput" class="ifk-input" placeholder="Nombre del alumno">
                    </div>
                    
                    <div class="pago-grid">
                        <div><label>FECHA:</label><input type="date" class="ifk-input" value="@DateTime.Now.ToString("yyyy-MM-dd")"></div>
                        <div><label>CONCEPTO:</label><input type="text" class="ifk-input"></div>
                    </div>

                    <div class="pago-grid" style="margin-top: 10px;">
                        <div><label>PAGO ($):</label><input type="number" id="inPagos" class="ifk-input" value="0" oninput="calcularTotal()"></div>
                        <div><label>PENDIENTES ($):</label><input type="number" id="inPendientes" class="ifk-input" value="0" oninput="calcularTotal()"></div>
                        <div><label>EXTRA ($):</label><input type="number" id="inExtra" class="ifk-input" value="0" oninput="calcularTotal()"></div>
                    </div>
                    
                    <div style="margin-top: 10px;">
                        <label>TOTAL FINAL (IVA 16%):</label>
                        <input type="text" id="totalInput" class="ifk-input" readonly>
                    </div>

                    <div style="margin-top: 15px;">
                        <label>MÉTODO DE PAGO:</label>
                        <select id="metodoPago" class="ifk-input" onchange="verificarMetodo()">
                            <option value="Efectivo">Efectivo</option>
                            <option value="Transferencia">Transferencia</option>
                        </select>
                        <div id="statusTransferencia" class="alert-transferencia">
                            * PENDIENTE A SELLAR O FIRMAR
                        </div>
                    </div>
                </div>

                <div class="registro-pago-container">
                    <button type="button" onclick="window.print()" class="btn-registrar-pago">IMPRIMIR RECIBO</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function calcularTotal() {
            const p = parseFloat(document.getElementById('inPagos').value) || 0;
            const pen = parseFloat(document.getElementById('inPendientes').value) || 0;
            const ex = parseFloat(document.getElementById('inExtra').value) || 0;
            const subtotal = p + pen + ex;
            const total = subtotal * 1.16;
            document.getElementById('totalInput').value = total.toFixed(2);
        }

        function verificarMetodo() {
            const select = document.getElementById('metodoPago');
            const status = document.getElementById('statusTransferencia');
            status.style.display = (select.value === 'Transferencia') ? 'block' : 'none';
        }

        const input = document.getElementById("inputBusqueda");
        const lista = document.getElementById("listaResultados");
        const nombreInput = document.getElementById("nombreAlumnoInput");

        input.addEventListener("input", function() {
            const query = this.value;
            if (query.length > 2) {
                fetch(`?handler=BuscarAlumnos&query=${query}`)
                    .then(res => res.json())
                    .then(data => {
                        lista.innerHTML = "";
                        if (data.length > 0) {
                            data.forEach(a => {
                                const div = document.createElement("div");
                                div.className = "item-resultado";
                                div.innerText = `${a.matricula} - ${a.nombre}`;
                                div.onclick = () => {
                                    nombreInput.value = a.nombre;
                                    input.value = "";
                                    lista.style.display = "none";
                                };
                                lista.appendChild(div);
                            });
                            lista.style.display = "block";
                        }
                    });
            } else { lista.style.display = "none"; }
        });
    </script>
</body>
</html>