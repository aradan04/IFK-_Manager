@page
@model InicioModel
@{
    ViewData["Title"] = "Inicio - IFK Manager";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Segoe UI', sans-serif;
        }

        body{
            background:#ececec;
        }

        .header{
            background:#111;
            color:#d4af37;
            height:70px;
            display:flex;
            align-items:center;
            justify-content:space-between;
            padding:0 30px;
        }

        .header-title{
            font-size:28px;
            font-weight:bold;
        }

        .logout{
            color:white;
            text-decoration:none;
            font-size:18px;
        }

        .container{
            display:flex;
            height:calc(100vh - 70px);
        }

        .sidebar{
            width:250px;
            background:#1d1d1d;
            color:white;
            padding-top:20px;
        }

        .sidebar a{
            display:block;
            color:white;
            text-decoration:none;
            padding:18px 25px;
            transition:0.3s;
        }

        .sidebar a:hover{
            background:#d4af37;
            color:black;
        }

        .sidebar i{
            width:25px;
        }

        .content{
            flex:1;
            padding:40px;
        }

        .welcome{
            text-align:center;
            font-size:50px;
            margin-bottom:40px;
        }

        .cards{
            display:flex;
            gap:25px;
            justify-content:center;
            flex-wrap:wrap;
        }

        .card{
            background:white;
            width:300px;
            min-height:220px;
            border-radius:12px;
            box-shadow:0 2px 10px rgba(0,0,0,.15);
            padding:25px;
            text-align:center;
        }

        .card h2{
            margin-bottom:20px;
            color:#444;
        }

        .card-number{
            font-size:70px;
            font-weight:bold;
            color:#d4af37;
        }

        .card-text{
            font-size:22px;
            font-weight:bold;
        }

    </style>
</head>
<body>

    <div class="header">
        <div class="header-title">
            IFK MANAGER
        </div>

        <a asp-page="/Index" class="logout">
            <i class="fas fa-sign-out-alt"></i>
            Cerrar sesión
        </a>
    </div>

    <div class="container">

        <div class="sidebar">

            <a asp-page="/Inicio">
                <i class="fas fa-home"></i>
                Inicio
            </a>

            <a asp-page="/Alumnos">
                <i class="fas fa-users"></i>
                Alumnos
            </a>

            <a asp-page="/Finanzas">
                <i class="fas fa-money-bill"></i>
                Finanzas
            </a>

            <a asp-page="/Torneos">
                <i class="fas fa-trophy"></i>
                Torneos
            </a>

            <a asp-page="/Reportes">
                <i class="fas fa-chart-bar"></i>
                Reportes
            </a>

            <a asp-page="/Configuracion">
                <i class="fas fa-cog"></i>
                Configuración
            </a>

        </div>

        <div class="content">

            <h1 class="welcome">
                Bienvenido de nuevo, Sensei.
            </h1>

            <div class="cards">

                <div class="card">
                    <h2>ALUMNOS ACTIVOS</h2>
                    <div class="card-number">
                        @Model.AlumnosActivos
                    </div>
                </div>

                <div class="card">
                    <h2>PAGOS PENDIENTES</h2>
                    <div class="card-number">
                        @Model.PagosPendientes
                    </div>
                </div>

                <div class="card">
                    <h2>SIGUIENTE TORNEO</h2>
                    <div class="card-text">
                        @Model.SiguienteTorneo
                    </div>
                </div>

            </div>

        </div>

    </div>

</body>
</html>