@page
@model InicioModel
@{
    ViewData["Title"] = "Inicio - IFK Manager";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/ifk.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <div class="header">
        <div class="header-title">
            IFK MANAGER
        </div>

        <a href="/Index" class="logout">
            <i class="fas fa-sign-out-alt"></i>
            Cerrar sesión
        </a>
    </div>

    <div class="container">

        <div class="sidebar">

            <a href="/Inicio">
                <i class="fas fa-home"></i>
                Inicio
            </a>

            <a href="/alumnos/gestion">
                <i class="fas fa-users"></i>
                Alumnos
            </a>

            <a href="/finanzas">
                <i class="fas fa-money-bill"></i>
                Finanzas
            </a>

            <a href="/torneos/gestorTorneo">
                <i class="fas fa-trophy"></i>
                Torneos
            </a>

            <a href="/Reportes">
                <i class="fas fa-chart-bar"></i>
                Reportes
            </a>

            <a href="/Configuracion">
                <i class="fas fa-cog"></i>
                Configuración
            </a>

        </div>

        <div class="content">

            <h1 class="welcome">
                Bienvenido de nuevo, Sensei.
            </h1>

            <div class="cards">

                <div class="card">
                    <h2>ALUMNOS ACTIVOS</h2>
                    <div class="card-number">
                        @Model.AlumnosActivos
                    </div>
                </div>

                <div class="card">
                    <h2>PAGOS PENDIENTES</h2>
                    <div class="card-number">
                        @Model.PagosPendientes
                    </div>
                </div>

                <div class="card">
                    <h2>SIGUIENTE TORNEO</h2>
                    <div class="card-text">
                        @Model.SiguienteTorneo
                    </div>
                </div>

            </div>

        </div>

    </div>

</body>
</html>