@page
@model ProyectoIFK.Pages.torneos.categoriasModel

@{
    ViewData["Title"] = "Categorías";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <title>Categorías</title>

    <link rel="stylesheet" href="~/css/ifk.css" />

    <link rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>

<body>

<div class="header">

    <div class="header-title">
        IFK MANAGER
    </div>

    <a href="/Index" class="logout">
        <i class="fas fa-sign-out-alt"></i>
        Cerrar sesión
    </a>

</div>

<div class="main">

    <div class="sidebar">

        <a href="/Inicio">
            <i class="fas fa-home"></i>
            Inicio
        </a>

        <a href="/alumnos/gestion">
            <i class="fas fa-users"></i>
            Alumnos
        </a>

        <a href="/finanzas">
            <i class="fas fa-money-bill"></i>
            Finanzas
        </a>

        <a href="/torneos/gestorTorneo">
            <i class="fas fa-trophy"></i>
            Torneos
        </a>

        <a href="/reportes">
            <i class="fas fa-chart-bar"></i>
            Reportes
        </a>

        <a href="/personal/menuPersonal">
            <i class="fas fa-user"></i>
            Personal
        </a>

    </div>

    <div class="content">

        <div class="page-box">

            <h1 class="categoria-title">
                CONFIGURACIÓN DE CATEGORÍA - COPA PRIMAVERA 2026
            </h1>

            <div class="categoria-divider"></div>

            <form method="post"
                    asp-page-handler="Previsualizar">

            <!-- NOMBRE -->

            <div class="categoria-nombre">

                <label>
                    NOMBRE DE CATEGORÍA
                </label>

                <input type="text"
                    name="NombreCategoria"
                    class="ifk-input"
                    value="@Model.NombreCategoria">

            </div>

            <!-- FILA 1 -->

            <div class="categoria-grid">

                <div>

                    <label>EDAD MÍNIMA</label>

                    <input type="number"
                        name="EdadMin"
                        class="ifk-input"
                        min="1"
                        max="99"
                        value="@Model.EdadMin">

                </div>

                <div>

                    <label>EDAD MÁXIMA</label>
                    <input type="number"
                        name="EdadMax"
                        class="ifk-input"
                        min="1"
                        max="99"
                        value="@Model.EdadMax">

                </div>

                <div>

                    <label>PESO MÍNIMO</label>

                    <input type="number"
                        name="PesoMin"
                        class="ifk-input"
                        min="1"
                        max="300"
                        step="0.1"
                        value="@Model.PesoMin">

                </div>

                <div>

                    <label>PESO MÁXIMO</label>

                    <input type="number"
                        name="PesoMax"
                        class="ifk-input"
                        min="1"
                        max="300"
                        step="0.1"
                        value="@Model.PesoMax">

                </div>

                <div>

                    <label>RAMA</label>

                    <select name="Rama"
                            class="ifk-input">

                        <option value="Varonil"
                                selected="@(Model.Rama == "Varonil")">
                            Varonil
                        </option>

                        <option value="Femenil"
                                selected="@(Model.Rama == "Femenil")">
                            Femenil
                        </option>

                        <option value="Mixto"
                                selected="@(Model.Rama == "Mixto")">
                            Mixto
                        </option>

                    </select>

                </div>

            </div>

            <!-- FILA 2 -->

            <div class="categoria-grid">

                <div>

                    <label>CINTA MÍNIMA</label>

                    <select name="CintaMin" class="ifk-input">

                        <option value="Blanca" selected="@(Model.CintaMin=="Blanca")">Blanca</option>
                        <option value="Amarilla" selected="@(Model.CintaMin=="Amarilla")">Amarilla</option>
                        <option value="Naranja" selected="@(Model.CintaMin=="Naranja")">Naranja</option>
                        <option value="Azul" selected="@(Model.CintaMin=="Azul")">Azul</option>
                        <option value="Verde" selected="@(Model.CintaMin=="Verde")">Verde</option>

                    </select>

                </div>

                <div>

                    <label>CINTA MÁXIMA</label>

                    <select name="CintaMax" class="ifk-input">

                        <option value="Amarilla" selected="@(Model.CintaMax=="Amarilla")">Amarilla</option>
                        <option value="Naranja" selected="@(Model.CintaMax=="Naranja")">Naranja</option>
                        <option value="Azul" selected="@(Model.CintaMax=="Azul")">Azul</option>
                        <option value="Verde" selected="@(Model.CintaMax=="Verde")">Verde</option>
                        <option value="Café" selected="@(Model.CintaMax=="Café")">Café</option>

                    </select>

                </div>

                <div class="categoria-btn-container">

                    <button type="submit"
                            class="btn-previsualizar">

                        PREVISUALIZAR GRUPO

                    </button>

                </div>

            </div>

            @if(ViewData["Mensaje"] != null)
            {
                <div class="alerta-torneo">
                    @ViewData["Mensaje"]
                </div>
            }

            <!-- TABLA -->

            <h2 class="categoria-subtitle">

                <i class="fas fa-users"></i>

                ALUMNOS ENCONTRADOS

            </h2>

            <table class="tabla-categorias">

                <thead>

                <tr>

                    <th>MATRÍCULA</th>
                    <th>NOMBRE DEL ALUMNO</th>
                    <th>EDAD</th>
                    <th>PESO</th>
                    <th>GRADO / CINTA</th>
                    <th>RAMA</th>

                </tr>

                </thead>

                <tbody>

                    @foreach(var alumno in Model.AlumnosEncontrados)
                    {
                        int edad =
                            DateTime.Today.Year -
                            alumno.FechaNacimiento.Year;

                        if(alumno.FechaNacimiento.Date >
                            DateTime.Today.AddYears(-edad))
                        {
                            edad--;
                        }

                        <tr>

                            <td>@alumno.Matricula</td>

                            <td>@alumno.NombreCompleto</td>

                            <td>@edad</td>

                            <td>@alumno.Peso kg</td>

                            <td>
                                @Model.ObtenerCinta(alumno.KyuActual)
                            </td>

                            <td>@alumno.Sexo</td>

                        </tr>
                    }

                    </tbody>

            </table>

            <!-- PIE -->

            <div class="categoria-footer">

                <div class="competidores-box">

                    <i class="fas fa-users"></i>

                    Competidores encontrados:

                    <strong>
                        @Model.AlumnosEncontrados.Count
                    </strong>

                </div>


                <button type="submit"
                        asp-page-handler="GuardarCategoria"
                        class="btn-guardar-categoria">

                    <i class="fas fa-save"></i>

                    GUARDAR CATEGORÍA

                </button>

            </div>

            </form>

        </div>

    </div>

</div>

</body>
</html>