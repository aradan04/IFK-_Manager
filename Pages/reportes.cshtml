@page

@{
    ViewData["Title"] = "Reportes";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Reportes</title>

    <link rel="stylesheet" href="~/css/ifk.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>

<body>

    <div class="header">

        <div class="header-title">
            IFK MANAGER
        </div>

        <a href="/Index" class="logout">
            <i class="fas fa-sign-out-alt"></i>
            Cerrar sesión
        </a>

    </div>

    <div class="main">

        <div class="sidebar">

            <a href="/Inicio">
                <i class="fas fa-home"></i>
                Inicio
            </a>

            <a href="/alumnos/gestion">
                <i class="fas fa-users"></i>
                Alumnos
            </a>

            <a href="/Finanzas">
                <i class="fas fa-money-bill"></i>
                Finanzas
            </a>

            <a href="/torneos/gestorTorneo">
                <i class="fas fa-trophy"></i>
                Torneos
            </a>

            <a href="/reportes">
                <i class="fas fa-chart-bar"></i>
                Reportes
            </a>

        </div>

        <div class="content">

            <div class="page-box">

                <h1 class="reportes-title">
                    GENERACIÓN DE REPORTES
                </h1>

                <div class="reportes-container">

                    <a href="#" class="reporte-card">

                        <div class="reporte-icon">
                            <img src="~/imagenes/icons/group.png"
                                 class="reporte-img">
                        </div>

                        <div class="reporte-btn">

                            <span>PADRÓN DE ALUMNOS</span>

                            <img src="~/imagenes/icons/file-pdf-solid.png"
                                alt="PDF"
                                class="pdf-icon">

                        </div>

                    </a>

                    <a href="#" class="reporte-card">

                        <div class="reporte-icon">
                            <img src="~/imagenes/icons/list-check-solid.png"
                                 class="reporte-img">
                        </div>

                        <div class="reporte-btn">
                            <span>LISTAS DE ASISTENCIA</span>
                            <img src="~/imagenes/icons/file-pdf-solid.png"
                                alt="PDF"
                                class="pdf-icon">
                        </div>

                    </a>

                    <a href="#" class="reporte-card">

                        <div class="reporte-icon">
                            <img src="~/imagenes/icons/file-excel-solid.png"
                                 class="reporte-img">
                        </div>

                        <div class="reporte-btn">
                            <span>ESTADOS DE CUENTA</span>
                            <img src="~/imagenes/icons/file-pdf-solid.png"
                                alt="PDF"
                                class="pdf-icon">
                        </div>

                    </a>

                    <a href="#" class="reporte-card">

                        <div class="reporte-icon">
                            <img src="~/imagenes/icons/medal-solid.png"
                                 class="reporte-img">
                        </div>

                        <div class="reporte-btn">
                            <span>RESULTADO DE TORNEO</span>
                            <img src="~/imagenes/icons/file-pdf-solid.png"
                                alt="PDF"
                                class="pdf-icon">
                        </div>

                    </a>

                </div>

                <h2 class="reportes-subtitle">
                    REPORTES GENERADOS RECIENTEMENTE
                </h2>

                <table class="tabla-reportes">

                    <thead>

                        <tr>
                            <th>NOMBRE DEL ARCHIVO</th>
                            <th>FECHA DE GENERACIÓN</th>
                            <th>USUARIO</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td>Padron_Alumnos_Abril.pdf</td>
                            <td>06/04/2026</td>
                            <td>Secretaria</td>
                        </tr>

                        <tr>
                            <td>Corte_Caja_Semana_1.pdf</td>
                            <td>05/04/2026</td>
                            <td>Sensei Roberto</td>
                        </tr>

                        <tr>
                            <td>Lista_Asistencia_Lunes.pdf</td>
                            <td>06/04/2026</td>
                            <td>Senpai Changuito</td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>
</html>