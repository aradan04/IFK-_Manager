@page
@model ProyectoIFK.Pages.ReportePagosModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <title>Estado de Cuenta</title>

    <style>

        body{
            font-family:Arial;
            margin:40px;
        }

        h1{
            text-align:center;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        th,td{
            border:1px solid black;
            padding:8px;
            text-align:center;
        }

        th{
            background:#dddddd;
        }

        .btn-print{
            margin-bottom:20px;
            padding:10px 20px;
            cursor:pointer;
        }

    </style>

</head>

<body>

    <button class="btn-print"
            onclick="window.print()">

        Imprimir / Guardar PDF

    </button>

    <h1>
        ESTADO DE CUENTA
    </h1>

    <p>
        Fecha de generación:
        @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
    </p>

    <table>

        <thead>

            <tr>

                <th>Alumno</th>
                <th>Concepto</th>
                <th>Monto</th>
                <th>Método</th>
                <th>Fecha</th>

            </tr>

        </thead>

        <tbody>

            @foreach(var pago in Model.Pagos)
            {
                <tr>

                    <td>
                        @pago.NombreCompleto
                    </td>

                    <td>
                        @pago.Concepto
                    </td>

                    <td>
                        $@pago.Monto
                    </td>

                    <td>
                        @pago.MetodoPago
                    </td>

                    <td>
                        @pago.FechaPago.ToString("dd/MM/yyyy")
                    </td>

                </tr>
            }

        </tbody>

    </table>

</body>

</html>