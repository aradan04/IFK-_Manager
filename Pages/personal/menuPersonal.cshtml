@page
@model ProyectoIFK.Pages.personal.personalModel

@{
    ViewData["Title"] = "Personal";
    Layout = null;
}

<!DOCTYPE html>

<html lang="es">
<head>

    <meta charset="utf-8" />

    <title>Personal</title>

    <link rel="stylesheet" href="~/css/ifk.css" />

    <link rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

</head>

<body>

    <div class="header">

        <div class="header-title">
            IFK MANAGER
        </div>

        <a href="/Index" class="logout">
            <i class="fas fa-sign-out-alt"></i>
            Cerrar sesión
        </a>

    </div>

    <div class="main">

        <div class="sidebar">

            <a href="/Inicio">
                <i class="fas fa-home"></i>
                Inicio
            </a>

            <a href="/alumnos/gestion">
                <i class="fas fa-users"></i>
                Alumnos
            </a>

            <a href="/finanzas">
                <i class="fas fa-money-bill"></i>
                Finanzas
            </a>

            <a href="/torneos/gestorTorneo">
                <i class="fas fa-trophy"></i>
                Torneos
            </a>

            <a href="/reportes">
                <i class="fas fa-chart-bar"></i>
                Reportes
            </a>

            <a href="/personal">
                <i class="fas fa-user"></i>
                Personal
            </a>

        </div>

        <div class="content">

            <div class="page-box">

                <h1 class="personal-title">
                    PERSONAL
                </h1>

                <p class="personal-subtitle">
                    Administra las herramientas relacionadas con el control del sistema.
                </p>

                <h2 class="personal-question">
                    ¿Qué desea administrar?
                </h2>

                <div class="personal-menu">

                    <div class="personal-card">

                        <i class="fas fa-clipboard-list personal-icon"></i>

                        <h2>
                            LOG DE AUDITORÍA
                        </h2>

                        <div class="personal-divider"></div>

                        <p>
                            Consulta todas las acciones realizadas dentro del sistema.
                        </p>

                        <a href="/personal/auditoria"
                            class="btn-personal">

                            INGRESAR

                        </a>

                    </div>

                    <div class="personal-card">

                        <i class="fas fa-users-cog personal-icon"></i>

                        <h2>
                            CONTROL DE ACCESO Y ROLES
                        </h2>

                        <div class="personal-divider"></div>

                        <p>
                            Administra los usuarios, roles y permisos del personal.
                        </p>

                        <a href="/personal/control"
                            class="btn-personal">

                            INGRESAR

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>
</html>